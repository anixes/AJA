# ──────────────────────────────────────────────────────────────────────────────
# AgentX & AJA - Unified Gitignore
# ──────────────────────────────────────────────────────────────────────────────

# --- System & IDEs ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- AgentX Runtime Data (DO NOT COMMIT) ---
.agentx/
.gsd/
temp_batons/
scratch/
graphify-out/
.graphify*
vault_data.json
speed_demon.log
path.txt
*.log
*.tmp
*.bak

# Exception: Allow the directory structure if needed (optional)
# !.agentx/
# .agentx/*
# !.agentx/config.json.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/
*.egg

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*
.next/
dist/
out/
.tauri/

# --- Rust / Native ---
target/
**/target/
*.pyd
*.so
*.dll
*.dylib
*.lib
*.pdb

# --- Databases & Large Files ---
*.lancedb/
*.arrow
*.db
*.db-journal
*.sqlite3
*.sqlite3-journal

# --- Secrets ---
.env
*.local
secrets.json

# --- External / Vendor ---
external/
vendor/

# --- Project Specific Overrides ---
# Allow specific config files that should be shared
!agentx.json
!providers.json
!SPEC.md
!README.md

# --- Hardware & Machine Specific Scripts ---
start_llama_*.bat
*.bat.local
*.ps1.local
benchmark_*.log

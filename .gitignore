# --- Rust / Native ---
target/
**/target/
*.pyd
*.so
*.dll
*.dylib
*.lib
*.pdb
**/*.rs.bk

# --- Databases & Large Files ---
*.lancedb/
*.arrow
*.db
*.db-journal

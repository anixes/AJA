{
  "project_name": "AgentX_Core",
  "territories": [
    {
      "path": "src/prod",
      "health_cmd": "node src/prod/app.ts",
      "auto_heal": true
    },
    {
      "path": "src/vault",
      "health_cmd": "ls src/vault",
      "auto_heal": false
    },
    {
      "path": "src/tools",
      "health_cmd": "ls src/tools",
      "auto_heal": true
    }
  ],
  "swarm_settings": {
    "offline_mode": true,
    "max_agents": 5,
    "check_interval": 30,
    "models": {
      "planner": "llama_cpp:gemma-4-e2b",
      "worker": "llama_cpp:gemma-4-e2b",
      "critic": "llama_cpp:gemma-4-e2b"
    },
    "operating_mode": "offline"
  }
}
{
  "project_name": "AgentX_Core",
  "territories": [
    {
      "path": "apps/cli-ts",
      "health_cmd": "node dist/cli.js",
      "auto_heal": true
    },
    {
      "path": "packages/agentx-core",
      "health_cmd": "python -m agentx status",
      "auto_heal": false
    }
  ],
  "swarm_settings": {
    "offline_mode": false,
    "max_agents": 5,
    "check_interval": 30,
    "models": {
      "planner": "google:gemini-2.5-flash",
      "worker": "google:gemini-2.5-flash",
      "critic": "google:gemini-2.5-flash"
    },
    "operating_mode": "online"
  }
}

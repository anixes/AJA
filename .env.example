# AJA Environment Configuration Template
# =========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# .env is listed in .gitignore and will not be tracked.

# ── Telegram Gateway (optional) ───────────────────────────────────────────────
# Obtain a bot token from @BotFather on Telegram.
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id-here

# ── Cloud LLM API Keys (set one or more) ──────────────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Local LLM (llama.cpp — optional, offline mode only) ───────────────────────
# URL of your running llama.cpp server (default: http://localhost:8080/v1)
# LLAMA_CPP_URL=http://localhost:8080/v1
# LLAMA_CPP_API_KEY=no-key-needed

# Path to your llama.cpp server binary (used only by offline launcher scripts)
# Example Linux/macOS: /usr/local/bin/llama-server
# Example Windows:     C:\tools\llama-server.exe
# LLAMA_SERVER_BIN=

# Path to your GGUF model file (used only by offline launcher scripts)
# Example Linux/macOS: /home/user/models/gemma-4b.gguf
# Example Windows:     C:\models\gemma-4b.gguf
# LLAMA_MODEL_PATH=

# ── Runtime Data Directory (optional) ─────────────────────────────────────────
# Overrides the default platform data directory for AJA runtime state.
# Default (Linux):   ~/.local/share/aja
# Default (Windows): %APPDATA%\aja
# Default (macOS):   ~/Library/Application Support/aja
# AJA_DATA_DIR=

# ── Python Interpreter (optional — normally auto-detected) ────────────────────
# Only set this if auto-detection picks the wrong Python.
# AJA_PYTHON=

# ── Numeric Thread Tuning (optional) ─────────────────────────────────────────
# Prevents OpenBLAS/MKL from spawning excessive threads during embedding.
# Uncomment if you observe CPU thrashing during sentence-transformer inference.
# OPENBLAS_NUM_THREADS=1
# OPENBLAS_MAIN_FREE=1
# KMP_DUPLICATE_LIB_OK=TRUE
# OMP_NUM_THREADS=1
# MKL_NUM_THREADS=1

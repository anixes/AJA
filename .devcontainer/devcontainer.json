{
  "name": "AJA Runtime Core Developer Environment",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  
  // Install global OS utilities and Rust toolchains
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest",
      "profile": "minimal"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    }
  },

  // Developer settings and VS Code extensions
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb"
      ]
    }
  },

  // Build the local pyo3 binary wheel extension automatically on environment creation
  "postCreateCommand": "pip install --upgrade pip maturin pytest anyio psutil && maturin develop && pip install -e .[all]",

  // Define environment variables
  "remoteEnv": {
    "AJA_DATA_DIR": "${containerWorkspaceFolder}/.data/aja"
  },

  "remoteUser": "vscode"
}

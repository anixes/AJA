{
  "name": "project1(no-name)",
  "version": "1.0.0",
  "description": "A high-performance agentic AI workflow engine and CLI tool inspired by modern agentic architectures.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "agentx": "./dist/cli.js"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "tsx apps/cli-ts/src/main.tsx",
    "dev:cli": "tsx apps/cli-ts/src/cli.ts",
    "build": "npm run build --workspaces",
    "start": "node apps/cli-ts/dist/main.js",
    "start:cli": "node apps/cli-ts/dist/cli.js",
    "aja": "node tools/start-aja.mjs",
    "start:aja": "node tools/start-aja.mjs",
    "dash": "set PYTHONPATH=libs/agentx-core && python -m agentx dash",
    "status": "set PYTHONPATH=libs/agentx-core && python -m agentx status",
    "test": "npm run test:ts && npm run test:py",
    "test:py": "pytest",
    "test:ts": "tsx tests/typescript/test_bash.ts && tsx tests/typescript/test_file_safety.ts && tsx tests/typescript/test_query.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
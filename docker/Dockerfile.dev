# syntax=docker/dockerfile:1.4
# Dev image: based on rust:stable so cargo/rustup are pre-installed & verified
FROM rust:stable AS rust-toolchain

FROM mcr.microsoft.com/devcontainers/python:1-3.11-bullseye

# Copy the pre-verified Rust toolchain from the official image
COPY --from=rust-toolchain /usr/local/cargo /usr/local/cargo
COPY --from=rust-toolchain /usr/local/rustup /usr/local/rustup

# Make Rust available to ALL users including vscode
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

RUN chmod -R a+rwx /usr/local/cargo /usr/local/rustup

RUN pip install --no-cache-dir maturin pytest anyio psutil

WORKDIR /workspace

# Add bootstrap script
RUN cat > /workspace/bootstrap.sh << 'EOF'
#!/usr/bin/env bash
set -e
echo "=== AJA Dev Bootstrap ==="
maturin develop --release
pip install -e ".[all]"
echo "=== Bootstrap complete. Run: aja doctor ==="
EOF
RUN chmod +x /workspace/bootstrap.sh

# Codebase is volume-mounted at /workspace for local dev.
CMD ["sleep", "infinity"]
